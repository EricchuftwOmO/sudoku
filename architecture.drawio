<mxfile host="app.diagrams.net">
  <diagram name="Architecture" id="sudoku-arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- AWS Cloud boundary -->
        <mxCell id="2" value="AWS Cloud" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#FF9900;strokeWidth=2;dashed=1;fontSize=14;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;" vertex="1" parent="1">
          <mxGeometry x="280" y="80" width="560" height="420" as="geometry" />
        </mxCell>

        <!-- User -->
        <mxCell id="3" value="User&#xa;(Browser)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="250" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- CloudFront -->
        <mxCell id="4" value="Amazon&#xa;CloudFront" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="250" width="120" height="60" as="geometry" />
        </mxCell>

        <!-- S3 Bucket -->
        <mxCell id="5" value="Amazon S3&#xa;(Private Bucket)&#xa;sudoku.html" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="250" width="140" height="60" as="geometry" />
        </mxCell>

        <!-- OAC -->
        <mxCell id="6" value="Origin Access Control (OAC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="380" width="180" height="40" as="geometry" />
        </mxCell>

        <!-- CDK -->
        <mxCell id="7" value="AWS CDK (Python)&#xa;Infrastructure as Code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="120" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- User -> CloudFront -->
        <mxCell id="10" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#232F3E;strokeWidth=2;fontSize=11;fontStyle=1;" edge="1" source="3" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CloudFront -> S3 -->
        <mxCell id="11" value="Origin Request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#232F3E;strokeWidth=2;fontSize=11;" edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- OAC to CloudFront -->
        <mxCell id="12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;dashed=1;endArrow=none;" edge="1" source="6" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- OAC to S3 -->
        <mxCell id="13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;dashed=1;endArrow=none;" edge="1" source="6" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CDK -> CloudFront -->
        <mxCell id="14" value="provisions" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;dashed=1;fontSize=10;" edge="1" source="7" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CDK -> S3 -->
        <mxCell id="15" value="provisions" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#b85450;dashed=1;fontSize=10;" edge="1" source="7" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
