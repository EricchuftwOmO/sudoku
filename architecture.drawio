<mxfile host="app.diagrams.net">
  <diagram name="Architecture" id="sudoku-arch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- AWS Cloud boundary -->
        <mxCell id="2" value="AWS Cloud" style="points=[[0,0],[0.25,0],[0.5,0],[0.75,0],[1,0],[1,0.25],[1,0.5],[1,0.75],[1,1],[0.75,1],[0.5,1],[0.25,1],[0,1],[0,0.75],[0,0.5],[0,0.25]];outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=1;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud;strokeColor=#232F3E;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="300" y="100" width="500" height="400" as="geometry" />
        </mxCell>

        <!-- User -->
        <mxCell id="3" value="User&#xa;(Browser)" style="shape=mxgraph.aws4.users;html=1;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;strokeColor=none;fillColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="100" y="260" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- CloudFront -->
        <mxCell id="4" value="Amazon&#xa;CloudFront" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudfront;html=1;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;strokeColor=none;fillColor=#8C4FFF;" vertex="1" parent="1">
          <mxGeometry x="420" y="260" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- S3 Bucket -->
        <mxCell id="5" value="Amazon S3&#xa;(Private Bucket)&#xa;sudoku.html" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;html=1;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;strokeColor=none;fillColor=#3F8624;" vertex="1" parent="1">
          <mxGeometry x="620" y="260" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- OAC -->
        <mxCell id="6" value="Origin Access&#xa;Control (OAC)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="490" y="370" width="120" height="40" as="geometry" />
        </mxCell>

        <!-- CDK -->
        <mxCell id="7" value="AWS CDK&#xa;(Python)" style="shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudformation;html=1;whiteSpace=wrap;fontSize=11;fontColor=#232F3E;strokeColor=none;fillColor=#E7157B;" vertex="1" parent="1">
          <mxGeometry x="520" y="140" width="60" height="60" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <!-- User -> CloudFront -->
        <mxCell id="10" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#232F3E;fontSize=10;" edge="1" source="3" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CloudFront -> S3 -->
        <mxCell id="11" value="Origin&#xa;Request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#232F3E;fontSize=10;" edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- OAC connection -->
        <mxCell id="12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;dashed=1;fontSize=10;" edge="1" source="6" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#d6b656;dashed=1;fontSize=10;" edge="1" source="6" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- CDK manages -->
        <mxCell id="14" value="provisions" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E7157B;dashed=1;fontSize=10;" edge="1" source="7" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="15" value="provisions" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#E7157B;dashed=1;fontSize=10;" edge="1" source="7" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
